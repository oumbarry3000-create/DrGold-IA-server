PORT=3001

# Clé AES-256 en hex (32 bytes = 64 chars hex)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERER_UNE_CLE_ICI

# Firebase Admin SDK — coller le contenu JSON du service account en une ligne
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"drgold-ia",...}
